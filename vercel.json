{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-src 'self' https://iframe.mediadelivery.net https://player.mediadelivery.net;"
        },
        {
          "key": "Permissions-Policy",
          "value": "autoplay=*, fullscreen=*"
        }
      ]
    }
  ]
}
