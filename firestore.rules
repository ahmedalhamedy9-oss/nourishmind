rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /courses/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
    match /certificates/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
    match /users/{id} {
      allow read: if request.auth != null && (request.auth.uid == id || request.auth.token.email == 'ahmedalhamedy9@gmail.com');
      allow write: if request.auth != null && (request.auth.uid == id || request.auth.token.email == 'ahmedalhamedy9@gmail.com');
    }
    match /reviews/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
    match /tools/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
    match /certificate_requests/{id} {
      allow read: if request.auth != null && (request.auth.uid == id || request.auth.token.email == 'ahmedalhamedy9@gmail.com');
      allow write: if request.auth != null && (request.auth.uid == id || request.auth.token.email == 'ahmedalhamedy9@gmail.com');
    }

    // ── PsychDecide audit log (#4) — patient data: strictest collection ──
    // Physician reads only their own reports; admin reads all.
    // Create-only, ownership-stamped; immutable (no updates); admin-only delete.
    match /auditLogs/{id} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         request.auth.token.email == 'ahmedalhamedy9@gmail.com');

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if false;

      allow delete: if request.auth != null &&
        request.auth.token.email == 'ahmedalhamedy9@gmail.com';
    }
  }
}
